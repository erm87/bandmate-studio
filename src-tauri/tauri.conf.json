{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BandMate Studio",
  "version": "0.1.0",
  "identifier": "com.brigades.bandmate-studio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BandMate Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Music",
    "shortDescription": "Modern companion app for the JoeCo BandMate hardware.",
    "longDescription": "BandMate Studio organizes multitrack audio and MIDI into songs and playlists, then writes them to a USB stick in the layout the BandMate hardware expects. A modern open-source alternative to JoeCo's BM Loader."
  },
  "plugins": {}
}
